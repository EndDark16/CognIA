# CognIA Backend - Environment Template
# Do not put real secrets in this file.

APP_CONFIG_CLASS=config.settings.ProductionConfig
PORT=5000
DEV_DEBUG=false

# Core secrets
SECRET_KEY=changeme
MFA_ENCRYPTION_KEY=base64-urlsafe-32bytes-key

# Database (production with Supabase - official production source of truth)
# In production, do not run a local Postgres container for CognIA.
DB_USER=api_backend.<project_ref>
DB_PASSWORD=<supabase_db_password>
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_SSL_MODE=require

# Optional local Docker Postgres profile (development only):
# Use with: docker compose --profile local-db up -d --build backend
# POSTGRES_* variables are only for initializing the local Postgres container.
# Never reuse Supabase users in POSTGRES_USER.
# Changing POSTGRES_USER after creating volume pgdata does not auto-create new roles.
# POSTGRES_USER=cognia_app
# POSTGRES_PASSWORD=<local_secret>
# POSTGRES_DB=cognia_db
# DB_USER=cognia_app
# DB_PASSWORD=<local_secret>
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=cognia_db
# DB_SSL_MODE=disable
MIGRATION_DB_USER=
MIGRATION_DB_PASSWORD=

# Auth/JWT cookies
JWT_COOKIE_SAMESITE=None
JWT_COOKIE_SECURE=true
JWT_COOKIE_DOMAIN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
FRONTEND_URL=http://localhost:3000
# If frontend/backend run on different domains (e.g. Vercel + Render or custom domain), keep
# CORS_ORIGINS aligned with the exact frontend origin and configure JWT_COOKIE_DOMAIN accordingly.
#
# Production profile A (Render backend + Vercel frontend):
# FRONTEND_URL=https://cogn-ia-frontend.vercel.app
# CORS_ORIGINS=https://cogn-ia-frontend.vercel.app,http://localhost:3000,http://localhost:5000
# JWT_COOKIE_SAMESITE=None
# JWT_COOKIE_SECURE=true
# JWT_COOKIE_DOMAIN=
#
# Production profile B (custom apex domain):
# FRONTEND_URL=https://www.cognia.lat
# CORS_ORIGINS=https://www.cognia.lat,https://cognia.lat,http://localhost:3000,http://localhost:5000
# JWT_COOKIE_SAMESITE=Lax
# JWT_COOKIE_SECURE=true
# JWT_COOKIE_DOMAIN=.cognia.lat

# Migrations
RUN_MIGRATIONS=true
SKIP_MIGRATIONS=false
DB_RETRIES=10
DB_RETRY_SLEEP=3

# Metrics
METRICS_TOKEN=
METRICS_TOKEN_REQUIRED=false
METRICS_ENABLED=true

# Email / SMTP
EMAIL_ENABLED=false
EMAIL_SEND_ASYNC=true
EMAIL_SANDBOX=true
EMAIL_FROM="CognIA <no-reply@example.com>"
EMAIL_REPLY_TO=
EMAIL_LIST_UNSUBSCRIBE=
EMAIL_UNSUBSCRIBE_URL=
EMAIL_UNSUBSCRIBE_SECRET=
EMAIL_UNSUBSCRIBE_TOKEN_TTL_DAYS=
EMAIL_UNSUBSCRIBE_RATE_LIMIT=10 per 10 minutes
EMAIL_ASSET_BASE_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_PORT__TLS=587
SMTP_PORT__SSL=
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_DEBUG=false
SMTP_TIMEOUT=10
TEST_SMTP_TO=

# Security / Limits
PASSWORD_MIN_LENGTH=8
PASSWORD_INPUT_MAX=200
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_PATH=/reset-password
PASSWORD_CHANGE_RATE_LIMIT=5 per 10 minutes
PASSWORD_FORGOT_RATE_LIMIT=5 per 10 minutes
PASSWORD_FORGOT_RATE_LIMIT_IP=20 per 10 minutes
PASSWORD_FORGOT_RATE_LIMIT_EMAIL=5 per 10 minutes
PASSWORD_RESET_RATE_LIMIT=5 per 10 minutes
PASSWORD_VERIFY_RATE_LIMIT=20 per 10 minutes

# Cookies/session
AUTH_CROSS_SITE_COOKIES=true

# Questionnaire Runtime v1
QR_PROCESS_ASYNC=true
QR_LIVE_HEARTBEAT_GRACE_SECONDS=45
QR_RETENTION_DRAFT_DAYS=30
QR_RETENTION_COMPLETED_DAYS=1095
QR_RETENTION_DELETED_DAYS=90
QR_RETENTION_NOTIFICATION_DAYS=180
QR_PIN_MAX_ATTEMPTS=5
QR_PIN_LOCK_MINUTES=10
QV2_SHARED_ACCESS_RATE_LIMIT=30 per minute
QV2_TRANSPORT_KEY_RATE_LIMIT=60 per minute
PREDICT_RATE_LIMIT=30 per minute

# CognIA field encryption at rest
COGNIA_ENABLE_FIELD_ENCRYPTION=false
COGNIA_FIELD_ENCRYPTION_KEY=
COGNIA_FIELD_ENCRYPTION_KEY_ID=field-key-v1
# Generate COGNIA_FIELD_ENCRYPTION_KEY with a 32-byte URL-safe key (base64 URL-safe).

# CognIA transport payload encryption
COGNIA_TRANSPORT_PAYLOAD_ENCRYPTION=false
COGNIA_TRANSPORT_REQUIRE_ENCRYPTION_PROD=true
COGNIA_TRANSPORT_ALLOW_PLAINTEXT_IN_DEV=true
COGNIA_TRANSPORT_PRIVATE_KEY_PEM=
COGNIA_TRANSPORT_KEY_ID=transport-key-v1
COGNIA_TRANSPORT_KEY_TTL_SECONDS=3600
# COGNIA_TRANSPORT_PRIVATE_KEY_PEM must contain only the backend private key (never expose it).
# Public key bootstrap endpoint is GET /api/v2/security/transport-key.

# Optional blueprint loading policy
OPTIONAL_BLUEPRINTS_STRICT=true
OPTIONAL_BLUEPRINTS_REQUIRED=questionnaire_runtime,questionnaire_v2

# Problem reports
PROBLEM_REPORT_UPLOAD_DIR=artifacts/problem_reports/uploads
PROBLEM_REPORT_MAX_ATTACHMENT_BYTES=5242880
PROBLEM_REPORT_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp

# SonarCloud
SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=
SONAR_PROJECT_KEY=EndDark16_CognIA
SONAR_ORGANIZATION=enddark16
